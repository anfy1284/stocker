# Пример конфигурации Stocker. Скопируйте в .env и заполните.
# Файл .env в репозиторий не коммитится (см. .gitignore).

# Ключ Anthropic API (платный, с оплатой по токенам — НЕ подписка Claude Pro).
# Нужен для классификации (Шаг 3) и метаданных (Шаг 10).
ANTHROPIC_API_KEY=

# Доступы Shutterstock для FTPS-заливки (Шаг B трека загрузки, команда
# `stocker upload`). Логин и пароль контрибьютора Shutterstock. Без них
# `upload` соберёт только CSV, но не зальёт изображения.
STOCKER_SHUTTERSTOCK_USER=
STOCKER_SHUTTERSTOCK_PASSWORD=

# Пути. Если не заданы — всё складывается в <корень проекта>/data.
# STOCKER_DATA_DIR=D:\Andrey\stocker\data
# STOCKER_INBOX_DIR=D:\Andrey\stocker\data\inbox
# Рабочие папки: сток-кандидаты и одобренные физически лежат отдельно, чтобы
# удобно фотошопить их изолированно (файлы двигаются автоматически по статусу).
# STOCKER_STOCK_DIR=D:\Andrey\stocker\data\stock
# STOCKER_APPROVED_DIR=D:\Andrey\stocker\data\approved
# STOCKER_PREVIEWS_DIR=D:\Andrey\stocker\data\previews
# STOCKER_LOGS_DIR=D:\Andrey\stocker\data\logs
# STOCKER_EXPORT_DIR=D:\Andrey\stocker\data\export
# STOCKER_DB_PATH=D:\Andrey\stocker\data\stocker.db

# Уровень логирования: DEBUG / INFO / WARNING / ERROR.
# STOCKER_LOG_LEVEL=INFO
