# Пример конфигурации Stocker. Скопируйте в .env и заполните.
# Файл .env в репозиторий не коммитится (см. .gitignore).

# Ключ Anthropic API (платный, с оплатой по токенам — НЕ подписка Claude Pro).
# Нужен для классификации (Шаг 3) и метаданных (Шаг 10).
ANTHROPIC_API_KEY=

# Доступы Shutterstock для FTPS-заливки (Шаг B трека загрузки, команда
# `stocker upload`). Логин и пароль контрибьютора Shutterstock. Без них
# `upload` соберёт только CSV, но не зальёт изображения.
STOCKER_SHUTTERSTOCK_USER=
STOCKER_SHUTTERSTOCK_PASSWORD=

# Пути. Если не заданы — всё складывается в <корень проекта>/data.
# STOCKER_DATA_DIR=D:\Andrey\stocker\data
# STOCKER_INBOX_DIR=D:\Andrey\stocker\data\inbox
# Рабочие папки: у каждой «кучи» интерфейса своя физическая папка, и файлы
# двигаются по ним автоматически при смене статуса — чтобы обрабатывать снимки
# внешними средствами (фотошопить «Сток»/«Одобрено», удалять «Брак»/«Выгружено»).
# STOCKER_STOCK_DIR=D:\Andrey\stocker\data\stock
# STOCKER_NON_STOCK_DIR=D:\Andrey\stocker\data\non_stock
# STOCKER_APPROVED_DIR=D:\Andrey\stocker\data\approved
# STOCKER_REJECTED_DIR=D:\Andrey\stocker\data\rejected
# STOCKER_DONE_DIR=D:\Andrey\stocker\data\done
# STOCKER_PREVIEWS_DIR=D:\Andrey\stocker\data\previews
# STOCKER_LOGS_DIR=D:\Andrey\stocker\data\logs
# STOCKER_EXPORT_DIR=D:\Andrey\stocker\data\export
# STOCKER_DB_PATH=D:\Andrey\stocker\data\stocker.db
# STOCKER_PREFILTERED_DIR=D:\Andrey\stocker\data\prefiltered
# STOCKER_MODELS_DIR=D:\Andrey\stocker\data\models     # кеш весов эстетики

# --- Локальный предотбор (GPU, без API) --------------------------------------
# Прогоняет архив дешёвой моделью на видеокарте и отсеивает явный не-сток до
# платного API. Порог эстетики 1–10: ниже — в «Предотсев». Меньше = мягче
# (больше уходит в API), больше = агрессивнее. Порог можно менять и
# перекладывать кучи без повторного прогона: `stocker prefilter --rethreshold`.
# STOCKER_PREFILTER_THRESHOLD=5.5
# Брать в платный классификатор ТОЛЬКО прошедших предотбор. Включи на машине с
# большим массивом фото, чтобы авто-разбор не тратил API на неотфильтрованное.
# STOCKER_PREFILTER_REQUIRED=1
# Локальный файл весов эстетики (если ПК без интернета для разовой загрузки).
# STOCKER_AESTHETIC_WEIGHTS=D:\Andrey\stocker\data\models\sac+logos+ava1-l14-linearMSE.pth

# Уровень логирования: DEBUG / INFO / WARNING / ERROR.
# STOCKER_LOG_LEVEL=INFO
